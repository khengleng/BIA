// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multi-tenant support
model Tenant {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users                    User["debian-openssl-3.0.x", ]
  smes                     SME["debian-openssl-3.0.x", ]
  investors                Investor["debian-openssl-3.0.x", ]
  advisors                 Advisor["debian-openssl-3.0.x", ]
  deals                    Deal["debian-openssl-3.0.x", ]
  workflows                Workflow["debian-openssl-3.0.x", ]
  documents                Document["debian-openssl-3.0.x", ]
  notifications            Notification["debian-openssl-3.0.x", ]
  pushSubscriptions        PushSubscription["debian-openssl-3.0.x", ]
  conversations            Conversation["debian-openssl-3.0.x", ]
  matches                  Match["debian-openssl-3.0.x", ]
  payments                 Payment["debian-openssl-3.0.x", ]
  subscriptions            Subscription["debian-openssl-3.0.x", ]
  invoices                 Invoice["debian-openssl-3.0.x", ]
  supportTickets           SupportTicket["debian-openssl-3.0.x", ]
  disputes                 Dispute["debian-openssl-3.0.x", ]
  cases                    AdminCase["debian-openssl-3.0.x", ]
  onboardingTemplates      OnboardingTemplate["debian-openssl-3.0.x", ]
  onboardingTasks          OnboardingTask["debian-openssl-3.0.x", ]
  roleChangeRequests       RoleChangeRequest["debian-openssl-3.0.x", ]
  temporaryRoleGrants      TemporaryRoleGrant["debian-openssl-3.0.x", ]
  advisorCapacities        AdvisorCapacity["debian-openssl-3.0.x", ]
  advisorAssignments       AdvisorAssignment["debian-openssl-3.0.x", ]
  advisorConflicts         AdvisorConflictDeclaration["debian-openssl-3.0.x", ]
  retentionRules           DataRetentionRule["debian-openssl-3.0.x", ]
  legalHolds               LegalHold["debian-openssl-3.0.x", ]
  reconciliationRuns       ReconciliationRun["debian-openssl-3.0.x", ]
  reconciliationExceptions ReconciliationException["debian-openssl-3.0.x", ]
  activityLogs             ActivityLog["debian-openssl-3.0.x", ]
  wallets                  Wallet["debian-openssl-3.0.x", ]
  walletTransactions       WalletTransaction["debian-openssl-3.0.x", ]
  LaunchpadOffering        LaunchpadOffering["debian-openssl-3.0.x", ]
  LaunchpadCommitment      LaunchpadCommitment["debian-openssl-3.0.x", ]

  @@map("tenants")
}

// User management with multi-tenancy
model User {
  id               String     @id @default(cuid())
  tenantId         String
  email            String
  password         String
  firstName        String
  lastName         String
  role             UserRole
  status           UserStatus @default(ACTIVE)
  language         Language   @default(EN)
  did              String? // DID from existing infrastructure
  resetToken       String?
  resetTokenExpiry DateTime?

  // Two-Factor Authentication
  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String["debian-openssl-3.0.x", ] @default(["debian-openssl-3.0.x", ])

  // Email Verification
  isEmailVerified         Boolean   @default(false)
  verificationToken       String?
  verificationTokenExpiry DateTime?
  preferences             Json      @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant                           Tenant                       @relation(fields: ["debian-openssl-3.0.x", tenantId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  sme                              SME?                         @relation("SMEUser")
  investor                         Investor?                    @relation("InvestorUser")
  advisor                          Advisor?                     @relation("AdvisorUser")
  notifications                    Notification["debian-openssl-3.0.x", ]
  pushSubscriptions                PushSubscription["debian-openssl-3.0.x", ]
  messageParticipants              ConversationParticipant["debian-openssl-3.0.x", ]
  sentMessages                     Message["debian-openssl-3.0.x", ]
  bookings                         Booking["debian-openssl-3.0.x", ]
  matchInterests                   MatchInterest["debian-openssl-3.0.x", ]
  payments                         Payment["debian-openssl-3.0.x", ]
  initiatedDisputes                Dispute["debian-openssl-3.0.x", ]                    @relation("DisputeInitiator")
  resolvedDisputes                 Dispute["debian-openssl-3.0.x", ]                    @relation("DisputeResolver")
  activityLogs                     ActivityLog["debian-openssl-3.0.x", ]
  agreementSignatures              AgreementSigner["debian-openssl-3.0.x", ]
  requestedSupportTickets          SupportTicket["debian-openssl-3.0.x", ]              @relation("TicketRequester")
  assignedSupportTickets           SupportTicket["debian-openssl-3.0.x", ]              @relation("TicketAssignee")
  requestedCases                   AdminCase["debian-openssl-3.0.x", ]                  @relation("CaseRequester")
  assignedCases                    AdminCase["debian-openssl-3.0.x", ]                  @relation("CaseAssignee")
  createdCases                     AdminCase["debian-openssl-3.0.x", ]                  @relation("CaseCreator")
  caseEvents                       AdminCaseEvent["debian-openssl-3.0.x", ]             @relation("CaseEventActor")
  onboardingTemplates              OnboardingTemplate["debian-openssl-3.0.x", ]         @relation("OnboardingTemplateCreator")
  onboardingTasks                  OnboardingTask["debian-openssl-3.0.x", ]             @relation("OnboardingTaskUser")
  assignedOnboardingTasks          OnboardingTask["debian-openssl-3.0.x", ]             @relation("OnboardingTaskAssignee")
  requestedRoleChanges             RoleChangeRequest["debian-openssl-3.0.x", ]          @relation("RoleChangeRequester")
  reviewedRoleChanges              RoleChangeRequest["debian-openssl-3.0.x", ]          @relation("RoleChangeReviewer")
  roleGrants                       TemporaryRoleGrant["debian-openssl-3.0.x", ]         @relation("RoleGrantTarget")
  grantedRolePrivileges            TemporaryRoleGrant["debian-openssl-3.0.x", ]         @relation("RoleGrantIssuer")
  advisorAssignmentCreator         AdvisorAssignment["debian-openssl-3.0.x", ]          @relation("AdvisorAssignmentCreator")
  advisorConflictReviewer          AdvisorConflictDeclaration["debian-openssl-3.0.x", ] @relation("AdvisorConflictReviewer")
  createdLegalHolds                LegalHold["debian-openssl-3.0.x", ]                  @relation("LegalHoldCreator")
  releasedLegalHolds               LegalHold["debian-openssl-3.0.x", ]                  @relation("LegalHoldReleaser")
  createdReconciliationRuns        ReconciliationRun["debian-openssl-3.0.x", ]          @relation("ReconciliationRunCreator")
  assignedReconciliationExceptions ReconciliationException["debian-openssl-3.0.x", ]    @relation("ReconciliationExceptionAssignee")
  invoices                         Invoice["debian-openssl-3.0.x", ]                    @relation("InvoiceCustomer")

  wallet        Wallet?
  refreshTokens RefreshToken["debian-openssl-3.0.x", ]

  @@unique(["debian-openssl-3.0.x", tenantId, email])
  @@map("users")
}

model RefreshToken {
  id              String   @id @default(cuid())
  token           String   @unique
  userId          String
  user            User     @relation(fields: ["debian-openssl-3.0.x", userId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  expiresAt       DateTime
  revoked         Boolean  @default(false)
  replacedByToken String?
  ipAddress       String?
  userAgent       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Added updateddAt for good measure

  @@index(["debian-openssl-3.0.x", userId])
  @@map("refresh_tokens")
}

// SME Module
model SME {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String    @unique
  name              String
  sector            String
  stage             SMEStage
  fundingRequired   Float
  description       String?
  website           String?
  location          String?
  score             Float?    @default(0)
  certified         Boolean   @default(false)
  certificationDate DateTime?
  status            SMEStatus @default(DRAFT)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  tenant         Tenant          @relation(fields: ["debian-openssl-3.0.x", tenantId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  user           User            @relation("SMEUser", fields: ["debian-openssl-3.0.x", userId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  documents      Document["debian-openssl-3.0.x", ]
  deals          Deal["debian-openssl-3.0.x", ]
  certifications Certification["debian-openssl-3.0.x", ]
  workflows      Workflow["debian-openssl-3.0.x", ]
  dueDiligences  DueDiligence["debian-openssl-3.0.x", ] // New: Due diligence assessments
  matches        Match["debian-openssl-3.0.x", ]

  @@map("smes")
}

// Investor Module
model Investor {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String         @unique
  name        String
  type        InvestorType
  kycStatus   KYCStatus      @default(PENDING)
  status      InvestorStatus @default(ACTIVE)
  preferences Json           @default("{}")
  portfolio   Json           @default("["debian-openssl-3.0.x", ]")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  tenant               Tenant             @relation(fields: ["debian-openssl-3.0.x", tenantId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  user                 User               @relation("InvestorUser", fields: ["debian-openssl-3.0.x", userId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  dealInvestments      DealInvestor["debian-openssl-3.0.x", ]
  workflows            Workflow["debian-openssl-3.0.x", ]
  leadSyndicates       Syndicate["debian-openssl-3.0.x", ]        @relation("LeadInvestor") // New: Syndicates led
  syndicateMemberships SyndicateMember["debian-openssl-3.0.x", ] // New: Syndicate memberships
  secondaryListings    SecondaryListing["debian-openssl-3.0.x", ] @relation("ListingSeller")
  tradesAsBuyer        SecondaryTrade["debian-openssl-3.0.x", ]   @relation("TradeBuyer")
  tradesAsSeller       SecondaryTrade["debian-openssl-3.0.x", ]   @relation("TradeSeller")
  matches              Match["debian-openssl-3.0.x", ]

  // Token Trading
  tokenListings       SyndicateTokenListing["debian-openssl-3.0.x", ]
  tokenTradesAsBuyer  SyndicateTokenTrade["debian-openssl-3.0.x", ]   @relation("TokenTradeBuyer")
  tokenTradesAsSeller SyndicateTokenTrade["debian-openssl-3.0.x", ]   @relation("TokenTradeSeller")
  LaunchpadCommitment LaunchpadCommitment["debian-openssl-3.0.x", ]

  @@map("investors")
}

// Advisor Module
model Advisor {
  id                String        @id @default(cuid())
  tenantId          String
  userId            String        @unique
  name              String
  specialization    String["debian-openssl-3.0.x", ]
  certificationList String["debian-openssl-3.0.x", ]
  status            AdvisorStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  tenant               Tenant                       @relation(fields: ["debian-openssl-3.0.x", tenantId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  user                 User                         @relation("AdvisorUser", fields: ["debian-openssl-3.0.x", userId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  certifications       Certification["debian-openssl-3.0.x", ]
  workflows            Workflow["debian-openssl-3.0.x", ]
  dueDiligences        DueDiligence["debian-openssl-3.0.x", ] // New: Due diligence conducted
  services             AdvisoryService["debian-openssl-3.0.x", ]
  bookings             Booking["debian-openssl-3.0.x", ]
  capacities           AdvisorCapacity["debian-openssl-3.0.x", ]
  assignments          AdvisorAssignment["debian-openssl-3.0.x", ]
  conflictDeclarations AdvisorConflictDeclaration["debian-openssl-3.0.x", ]

  @@map("advisors")
}

// Deal Room / Matchmaking
model Deal {
  id               String     @id @default(cuid())
  tenantId         String
  smeId            String
  title            String
  description      String?
  amount           Float
  equity           Float?
  status           DealStatus @default(DRAFT)
  successFee       Float?
  terms            String?
  isDocumentLocked Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  tenant            Tenant                       @relation(fields: ["debian-openssl-3.0.x", tenantId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  sme               SME                          @relation(fields: ["debian-openssl-3.0.x", smeId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  investors         DealInvestor["debian-openssl-3.0.x", ]
  documents         Document["debian-openssl-3.0.x", ]
  workflows         Workflow["debian-openssl-3.0.x", ]
  syndicates        Syndicate["debian-openssl-3.0.x", ] // New: Syndicates for this deal
  conversations     Conversation["debian-openssl-3.0.x", ]
  disputes          Dispute["debian-openssl-3.0.x", ]
  dueDiligenceItems DueDiligenceItem["debian-openssl-3.0.x", ]
  escrowAccount     EscrowAccount?
  agreements        Agreement["debian-openssl-3.0.x", ]
  advisorConflicts  AdvisorConflictDeclaration["debian-openssl-3.0.x", ]
  launchpadOffering LaunchpadOffering?

  @@map("deals")
}

// Many-to-many relationship between Deal and Investor
model DealInvestor {
  id         String           @id @default(cuid())
  dealId     String
  investorId String
  amount     Float
  status     InvestmentStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // Relations
  deal              Deal               @relation(fields: ["debian-openssl-3.0.x", dealId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  investor          Investor           @relation(fields: ["debian-openssl-3.0.x", investorId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  secondaryListings SecondaryListing["debian-openssl-3.0.x", ]
  payments          Payment["debian-openssl-3.0.x", ]

  @@unique(["debian-openssl-3.0.x", dealId, investorId])
  @@map("deal_investors")
}

// Document Management
model Document {
  id         String       @id @default(cuid())
  tenantId   String
  name       String
  type       DocumentType
  url        String
  size       Int
  mimeType   String
  smeId      String?
  dealId     String?
  uploadedBy String

  accessLevel AccessLevel @default(QUALIFIED)
  isLocked    Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: ["debian-openssl-3.0.x", tenantId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  sme    SME?   @relation(fields: ["debian-openssl-3.0.x", smeId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  deal   Deal?  @relation(fields: ["debian-openssl-3.0.x", dealId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)

  @@map("documents")
}

// Certification Workflow
model Certification {
  id        String              @id @default(cuid())
  smeId     String
  advisorId String
  status    CertificationStatus @default(PENDING)
  score     Float?
  comments  String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // Relations
  sme     SME     @relation(fields: ["debian-openssl-3.0.x", smeId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  advisor Advisor @relation(fields: ["debian-openssl-3.0.x", advisorId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)

  @@map("certifications")
}

// Workflow Management (integrated with DID workflow engine)
model Workflow {
  id            String         @id @default(cuid())
  tenantId      String
  type          WorkflowType
  status        WorkflowStatus @default(PENDING)
  data          Json           @default("{}")
  smeId         String?
  investorId    String?
  advisorId     String?
  dealId        String?
  didWorkflowId String? // Reference to DID workflow engine
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: ["debian-openssl-3.0.x", tenantId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  sme      SME?      @relation(fields: ["debian-openssl-3.0.x", smeId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  investor Investor? @relation(fields: ["debian-openssl-3.0.x", investorId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  advisor  Advisor?  @relation(fields: ["debian-openssl-3.0.x", advisorId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  deal     Deal?     @relation(fields: ["debian-openssl-3.0.x", dealId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)

  @@map("workflows")
}

// ==================== NEW FEATURES ====================

// Investor Syndicate (like AngelList)
model Syndicate {
  id             String  @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  leadInvestorId String
  targetAmount   Float
  minInvestment  Float   @default(1000)
  maxInvestment  Float?
  managementFee  Float   @default(2.0) // Percentage
  carryFee       Float   @default(20.0) // Percentage of profits

  // Tokenization
  isTokenized   Boolean @default(false)
  tokenName     String?
  tokenSymbol   String?
  pricePerToken Float?
  totalTokens   Float?
  tokensSold    Float   @default(0)

  status      SyndicateStatus @default(FORMING)
  dealId      String?
  closingDate DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  leadInvestor  Investor                @relation("LeadInvestor", fields: ["debian-openssl-3.0.x", leadInvestorId], references: ["debian-openssl-3.0.x", id])
  deal          Deal?                   @relation(fields: ["debian-openssl-3.0.x", dealId], references: ["debian-openssl-3.0.x", id])
  members       SyndicateMember["debian-openssl-3.0.x", ]
  tokenListings SyndicateTokenListing["debian-openssl-3.0.x", ]

  @@map("syndicates")
}

model SyndicateMember {
  id          String                @id @default(cuid())
  syndicateId String
  investorId  String
  amount      Float
  tokens      Float?                @default(0) // Number of tokens owned
  status      SyndicateMemberStatus @default(PENDING)
  joinedAt    DateTime              @default(now())

  // Relations
  syndicate Syndicate @relation(fields: ["debian-openssl-3.0.x", syndicateId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  investor  Investor  @relation(fields: ["debian-openssl-3.0.x", investorId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)

  @@unique(["debian-openssl-3.0.x", syndicateId, investorId])
  @@map("syndicate_members")
}

model SyndicateTokenListing {
  id          String @id @default(cuid())
  syndicateId String
  sellerId    String

  tokensAvailable Float
  pricePerToken   Float
  minTokens       Float @default(1)

  status    ListingStatus @default(ACTIVE)
  listedAt  DateTime      @default(now())
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  syndicate Syndicate             @relation(fields: ["debian-openssl-3.0.x", syndicateId], references: ["debian-openssl-3.0.x", id])
  seller    Investor              @relation(fields: ["debian-openssl-3.0.x", sellerId], references: ["debian-openssl-3.0.x", id])
  trades    SyndicateTokenTrade["debian-openssl-3.0.x", ]

  @@map("syndicate_token_listings")
}

model SyndicateTokenTrade {
  id        String @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String

  tokens        Float
  pricePerToken Float
  totalAmount   Float
  fee           Float @default(0)

  status     TradeStatus @default(PENDING)
  executedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  listing SyndicateTokenListing @relation(fields: ["debian-openssl-3.0.x", listingId], references: ["debian-openssl-3.0.x", id])
  buyer   Investor              @relation("TokenTradeBuyer", fields: ["debian-openssl-3.0.x", buyerId], references: ["debian-openssl-3.0.x", id])
  seller  Investor              @relation("TokenTradeSeller", fields: ["debian-openssl-3.0.x", sellerId], references: ["debian-openssl-3.0.x", id])

  @@map("syndicate_token_trades")
}

// Due Diligence Scoring (like OurCrowd)
model DueDiligence {
  id        String  @id @default(cuid())
  smeId     String
  advisorId String?

  // Scoring Categories (0-100)
  financialScore   Float @default(0)
  teamScore        Float @default(0)
  marketScore      Float @default(0)
  productScore     Float @default(0)
  legalScore       Float @default(0)
  operationalScore Float @default(0)

  // Overall calculated score
  overallScore Float     @default(0)
  riskLevel    RiskLevel @default(MEDIUM)

  // Detailed assessments
  strengths       String["debian-openssl-3.0.x", ]
  weaknesses      String["debian-openssl-3.0.x", ]
  recommendations String["debian-openssl-3.0.x", ]
  redFlags        String["debian-openssl-3.0.x", ]

  status      AssessmentStatus @default(PENDING)
  completedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sme     SME      @relation(fields: ["debian-openssl-3.0.x", smeId], references: ["debian-openssl-3.0.x", id], onDelete: Cascade)
  advisor Advisor? @relation(fields: ["debian-openssl-3.0.x", advisorId], references: ["debian-openssl-3.0.x", id])

  @@map("due_diligences")
}

// Community Features (like Wefunder)
model CommunityPost {
  id       String       @id @default(cuid())
  tenantId String
  authorId String
  title    String
