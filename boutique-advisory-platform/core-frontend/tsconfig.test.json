{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/lib/api.ts",
    "src/lib/permissions.ts",
    "src/app/api-proxy/api/[...path]/route.ts",
    "src/tests/**/*.test.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
